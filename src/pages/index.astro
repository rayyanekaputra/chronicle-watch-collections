---
import "../styles/main.scss";
import { Image } from "astro:assets";
import heroImage from "../images/pexels-zeeshaanshabbir-9200228.jpg";
---

<style>
	@import url("https://fonts.googleapis.com/css2?family=Archivo+Narrow:ital,wght@0,400..700;1,400..700&family=Boldonse&display=swap");
	* {
		box-sizing: content-box;
		margin: 0;
		padding: 0;
	}
	body {
		display: flex;
		flex-direction: column;
		/* height: 8000px; */
		/* display: block; */
	}
	.hero-section {
		background-image: url(../images/pexels-zeeshaanshabbir-9200228.jpg);
		background-size: cover;
		background-repeat: no-repeat;

		width: 100vw;
		height: 100vh;

		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1;
	}

	.sticky-section-1{
		position: sticky;
		top:0;
		z-index: 1;
	}
	.sticky-section-2{
		position: sticky;
		top:0;
		z-index: 2;
	}
	.sticky-section-3{
		position: sticky;
		top:0;
		z-index: 3;
	}

	h1 {
		font-family: "Boldonse";
		color: white;
	}
	p {
		font-family: "Archivo Narrow";
		font-weight: 400;
		font-size: 10px;
		color: white;
	}

	.navigation-bar {
		position: sticky;
		top: 0;
		/* background-color: yellow; */
		z-index: 99;

		ul {
			display: flex;
			flex-direction: row;
			list-style: none;
			column-gap: 32px;

			align-items: center;
			justify-content: center;

			margin-top: 20px;
			margin-bottom: -80px;
		}
	}
</style>

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>CHRONIC</title>
	</head>
	<body>
		<div class="navigation-bar">
			<ul>
				<li><p>HOME</p></li>
				<li><p>ABOUT</p></li>
				<li><p>WORKS</p></li>
			</ul>
		</div>
		<div>
			<section class="hero-section sticky-section-1">
				<h1>CHRONICLE</h1>
			</section>
			<section class="hero-section sticky-section-2">
				<h1>WATCH</h1>
			</section>
			<section class="hero-section sticky-section-3">
				<h1>COLLECTIONS</h1>
				
			</section>
		</div>
	</body>
</html>
