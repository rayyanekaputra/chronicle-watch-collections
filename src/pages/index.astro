---
import "../styles/main.scss";
---

<style>
	@import "locomotive-scroll/dist/locomotive-scroll.css";
	@import url("https://fonts.googleapis.com/css2?family=Archivo+Narrow:ital,wght@0,400..700;1,400..700&family=Boldonse&display=swap");
	* {
		box-sizing: content-box;
		margin: 0;
		padding: 0;
	}
	body {
		overscroll-behavior: none;
		display: flex;
		flex-direction: column;
		/* height: 8000px; */
		/* display: block; */
	}
	.hero-section {
		background-size: cover;
		background-repeat: no-repeat;

		width: 100vw;
		height: 100vh;

		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1;
	}

	.sticky-section-1 {
		background-image: url(../images/pexels-zeeshaanshabbir-9200228.jpg);
		position: sticky;
		top: 0;
		z-index: 1;
	}
	.sticky-section-2 {
		background-image: url(../images/pexels-ninetysevenyears-30508184.jpg);

		position: sticky;
		top: 0;
		z-index: 2;
	}
	.sticky-section-3 {
		background-image: url(../images/pexels-el-gringo-photo-116752370-10658200.jpg);

		position: sticky;
		top: 0;
		z-index: 3;
	}

	h1 {
		font-family: "Boldonse";
		color: white;
	}
	p {
		font-family: "Archivo Narrow";
		font-weight: 400;
		font-size: 10px;
		color: white;
	}

	.navigation-bar {
		position: sticky;
		top: 0;
		/* background-color: yellow; */
		z-index: 99;

		ul {
			display: flex;
			flex-direction: row;
			list-style: none;
			column-gap: 32px;

			align-items: center;
			justify-content: center;

			margin-top: 20px;
			margin-bottom: -80px;
		}
	}

	.horizontal-section-wrapper {
		display: flex;
		flex-direction: row;
		/* overflow: scroll; */
		overscroll-behavior: none;
		flex-wrap: nowrap;
		height: 100vh;
		z-index: 0;

		.box {
			/* width: 100vw; */
			flex: 0 0 100vw;
		}
		.box1 {
			background-image: url(../images/hori-1.jpg);
			background-size: cover;
		}
		.box2 {
			background-image: url(../images/hori-2.jpg);
			background-size: cover;
		}
		.box3 {
			background-image: url(../images/hori-3.jpg);
			background-size: cover;
		}
	}
	.angkat-view {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 1080px;
		width: 100vw;
		h1{
			color: black
		}
	}
</style>

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>CHRONIC</title>
	</head>
	<body>
		<div class="navigation-bar">
			<ul>
				<li><p>HOME</p></li>
				<li><p>ABOUT</p></li>
				<li><p>WORKS</p></li>
			</ul>
		</div>
		<div class="hero-section-wrapper">
			<section class="hero-section sticky-section-1">
				<h1 data-scroll data-scroll-speed="0.5">CHRONICLE</h1>
			</section>
			<section class="hero-section sticky-section-2">
				<h1 data-scroll data-scroll-speed="0.5">WATCH</h1>
			</section>
			<section class="hero-section sticky-section-3">
				<h1 data-scroll data-scroll-speed="0.5">COLLECTIONS</h1>
			</section>
		</div>
		<div class="horizontal-section-wrapper">
			<div class="box box1">BOX 1</div>
			<div class="box box2">BOX 2</div>
			<div class="box box3">BOX 3</div>
		</div>
		<div class="angkat-view">
			<h1>INI VIEW SELANJUTNYA</h1>
		</div>
	</body>
</html>

<script>
	//@ts-nocheck
	//SCRIPT ALWAYS RENDERED CLIENT-SIDE
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import LocomotiveScroll from "locomotive-scroll";
	const scroll = new LocomotiveScroll({
	lenisOptions: {
	lerp: 0.5,
	duration: 2,
	},
	});

	gsap.registerPlugin(ScrollTrigger);
	const boxes = gsap.utils.toArray(".box");
	const boxesWrapper = document.querySelector(".horizontal-section-wrapper");
	console.log(boxes);
	gsap.to(boxes, {
		ease: "none",
		xPercent: -100 * (boxes.length - 1),

		scrollTrigger: {
			trigger: boxesWrapper,
			markers: true,
			pin: true,
			scrub: 1,
			end: ()=>"+="+(boxesWrapper.offsetWidth+80) //+80 karena ada margin-bottom,
		},
	});
</script>
